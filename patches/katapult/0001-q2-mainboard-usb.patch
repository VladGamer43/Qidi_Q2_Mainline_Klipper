+    OTGD->DIEPEMPMSK = 0;
+    OTGD->DAINTMSK = 0;
+    OTGD->DAINT = 0xFFFFFFFF;
+    OTG->GOTGINT = 0xFFFFFFFF;
+    OTG->GINTSTS = 0xBFFFFFFF;
+}
