     OTGD->DCTL = 0;
+#if CONFIG_STM32F4_GD32_USB_INIT_WORKAROUND
+    // Ensure no global NAK state survives bootloader handoff.
+    OTGD->DCTL = USB_OTG_DCTL_CGINAK;
+    OTGD->DCTL = USB_OTG_DCTL_CGONAK;
+#endif
 }
 DECL_INIT(usb_init);
